PORT=3001
NODE_ENV=development
DATABASE_URL=postgres://socialops:change-me@localhost:5432/socialops

SOCIALOPS_API_URL=http://localhost:3001
SOCIALOPS_USER_EMAIL=dev@socialops.local
SOCIALOPS_USER_NAME=SocialOps Dev
# Optional. If omitted, the CLI uses the first workspace returned by the API.
SOCIALOPS_WORKSPACE_ID=

OPENPOST_URL=http://localhost:8080
SOCIALOPS_OPENPOST_INTERNAL_TOKEN=
MINICLAW_URL=http://localhost:18789
COMFYUI_URL=http://localhost:8188
VISUAL_WORKER_URL=http://localhost:3002
VIDEO_WORKER_URL=http://localhost:3003
DECK_WORKER_URL=http://localhost:3004
POKEE_RESEARCH_URL=http://localhost:8888

SOCIALOPS_MEDIA_RUNTIME_PROFILE=macbook_local
SOCIALOPS_ALLOW_HEAVY_MEDIA_WORKFLOWS=false

# Optional professional video providers. Leave blank unless you have approved
# accounts/keys; SocialOps will still plan provider-routed workflows without them.
HIGGSFIELD_API_KEY=
PIPPIT_API_KEY=
SEEDANCE_API_KEY=
AVATAR_PROVIDER_API_KEY=
